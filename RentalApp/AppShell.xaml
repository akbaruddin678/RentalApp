<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="RentalApp.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:RentalApp.Views"
       Shell.FlyoutBehavior="Disabled">
    <TabBar>
        <Tab Title="Browse">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsListPage}" />
        </Tab>
        <Tab Title="Near Me">
            <ShellContent ContentTemplate="{DataTemplate views:NearbyItemsPage}" />
        </Tab>
        <Tab Title="My Rentals">
            <ShellContent ContentTemplate="{DataTemplate views:RentalsPage}" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>
    </TabBar>
</Shell>
