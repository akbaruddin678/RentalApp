<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RentalApp.Views.CreateItemPage"
             Title="{Binding Title}">
    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Entry Text="{Binding ItemTitle}" Placeholder="Item Title" />
            <Editor Text="{Binding Description}" Placeholder="Description" HeightRequest="100" />
            <Entry Text="{Binding DailyRateText}" Placeholder="Daily Rate ($)" Keyboard="Numeric" />
            <Picker ItemsSource="{Binding Categories}" SelectedIndex="{Binding SelectedCategoryIndex}" Title="Select Category" />
            
            <HorizontalStackLayout Spacing="10">
                <Button Text="Get GPS Location" Command="{Binding GetLocationCommand}" />
                <Label Text="{Binding Location}" VerticalOptions="Center" />
            </HorizontalStackLayout>
            
            <Button Text="Save Listing" Command="{Binding SaveItemCommand}" Margin="0,20,0,0" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding HasError}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
