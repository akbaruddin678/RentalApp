<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:RentalApp.ViewModels"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:Class="RentalApp.Views.NearbyItemsPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto,Auto,*">
        <VerticalStackLayout Grid.Row="0" Padding="15" Spacing="10">
            <Label Text="{Binding SearchRadius, StringFormat='Search Radius: {0:F0} km'}" />
            <Slider Value="{Binding SearchRadius}" Minimum="1" Maximum="50" />
            <Button Text="Find Near Me" Command="{Binding FindNearbyCommand}" />
        </VerticalStackLayout>
        <Label Grid.Row="1" Text="{Binding StatusMessage}" HorizontalOptions="Center" Margin="0,10" />
        <CollectionView Grid.Row="2" ItemsSource="{Binding NearbyItems}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Item">
                    <Frame Margin="10,5" Padding="15">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NearbyItemsViewModel}}, Path=NavigateToDetailCommand}" CommandParameter="{Binding .}"/>
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout>
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="18" />
                            <Label Text="{Binding DailyRate, StringFormat='${0:F2}/day'}" TextColor="Green" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
