<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:Class="RentalApp.Views.RentalsPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="Auto,*,Auto,*">
        <Label Grid.Row="0" Text="Incoming Requests (Your Items)" FontAttributes="Bold" Margin="10" />
        <CollectionView Grid.Row="1" ItemsSource="{Binding IncomingRentals}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Rental">
                    <Frame Margin="10,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Item.Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Status, StringFormat='Status: {0}'}" />
                            <HorizontalStackLayout Spacing="10" Margin="0,10,0,0">
                                <Button Text="Approve" Command="{Binding BindingContext.ApproveCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                <Button Text="Reject" Command="{Binding BindingContext.RejectCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <Label Grid.Row="2" Text="Outgoing Rentals (Items you borrowed)" FontAttributes="Bold" Margin="10" />
        <CollectionView Grid.Row="3" ItemsSource="{Binding OutgoingRentals}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Rental">
                    <Frame Margin="10,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Item.Title}" FontAttributes="Bold" />
                            <Label Text="{Binding Status, StringFormat='Status: {0}'}" />
                            <Button Text="Return Item" Command="{Binding BindingContext.ReturnCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" Margin="0,10,0,0" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
