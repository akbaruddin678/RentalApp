<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:RentalApp.Database.Models;assembly=RentalApp.Database"
             x:Class="RentalApp.Views.ReviewsPage"
             Title="{Binding Title}">
    <Grid RowDefinitions="*,Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Reviews}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Review">
                    <Frame Margin="10,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding Rating, StringFormat='{0} Stars'}" FontAttributes="Bold" TextColor="Gold" />
                            <Label Text="{Binding Comment}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="10" BackgroundColor="#f0f0f0" IsVisible="{Binding CanReview}">
            <Label Text="Leave a Review" FontAttributes="Bold" />
            <Slider Minimum="1" Maximum="5" Value="{Binding NewRating}" />
            <Label Text="{Binding NewRating, StringFormat='Rating: {0:F0}'}" />
            <Entry Text="{Binding NewComment}" Placeholder="Write your comment..." />
            <Button Text="Submit Review" Command="{Binding SubmitReviewCommand}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
